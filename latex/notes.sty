% ---------- TikZ labeled math boxes ----------
% Creates the ability to add boxes and labels on parts of equations
\RequirePackage{tikz}
\usetikzlibrary{calc,shapes.geometric,arrows,positioning}
\newif\ifclipme\clipmetrue
\tikzset{
    labelstyle/.style={LabelStyle/.append style={#1}},
    linestyle/.style={LineStyle/.append style={#1}}
}
\tikzset{
    LabelStyle/.initial={},
    LineStyle/.initial={}
}
\newcommand{\brokenarrow}[5][0.2]{%
    % #1 = half-length of break slashes (optional, default 0.2)
    % #2 = x1 (start)
    % #3 = y1 (start)
    % #4 = x2 (end)
    % #5 = y2 (end)

    \def\slashlen{#1}
    \def\xstart{#2}
    \def\ystart{#3}
    \def\xend{#4}
    \def\yend{#5}

    % Compute break at 75% along the line
    \pgfmathsetmacro\xbreak{\xstart + 0.75*(\xend-\xstart)}
    \pgfmathsetmacro\ybreak{\ystart + 0.75*(\yend-\ystart)}

    % Draw top segment
    \draw[<-] (\xstart,\ystart) -- (\xbreak, \ybreak+0.1);

    % Draw bottom segment
    \draw[->] (\xbreak, \ybreak-0.1) -- (\xend, \yend);

    % Draw break slashes
    \draw[] (\xbreak-\slashlen, \ybreak) -- (\xbreak-0.05, \ybreak);
    \draw[] (\xbreak+0.05, \ybreak) -- (\xbreak+\slashlen, \ybreak);
}

\newcommand{\mathWithDescription}[4][]{{%
    \tikzset{#1}%
    \tikz[baseline]{
        \node[draw=red,rounded corners,anchor=base] (m#4) {$\displaystyle#2$};
        \ifclipme\begin{pgfinterruptboundingbox}\fi
            \node[above of=m#4,font=\strut, LabelStyle] (l#4) {#3};
            \draw[-,red, LineStyle] (l#4) to (m#4);
        \ifclipme\end{pgfinterruptboundingbox}\fi
    }%
}}
\newcommand{\mathWithDescriptionStarred}[3][]{{%
    \clipmefalse%
    \mathWithDescription[#1]{#2}{#3}{\themathLableNode}%
}}

\newcounter{mathLableNode}
\newcommand{\mlbox}[3][]{%
   \stepcounter{mathLableNode}%
   \mathWithDescription[#1]{#2}{#3}{\themathLableNode}%
   \vphantom{\mathWithDescriptionStarred[#1]{#2}{#3}{\themathLableNode}}%
}
