% ---------- Answer boxes ----------
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable,theorems}

\tcbset{
	ntextbox base/.style={
		enhanced,
		breakable,
		pad at break*=0.8em,
		boxrule=0.5pt,
		fonttitle=\bfseries,
		left=1.0em, right=1.0em, top=0.8em, bottom=0.8em,
		before upper={\parskip=0.8em},
	}
}

% produce a basic text box, styled for Adelaide Uni.
\newcommand{\textbox}[2]{
    \begin{tcolorbox}[
        enhanced,
        breakable,
        pad at break*=1mm,
        colback=aublue!2,
        colframe=aublue,
        title={#1},
        boxrule=0.5pt,
        fonttitle=\bfseries,
        left=1.0em, right=1.0em, top=0.8em, bottom=0.8em,
        before upper={\parskip=0.8em}
        ]
        #2
    \end{tcolorbox}
}

\newtcolorbox[auto counter, number within=chapter]{ntextboxenv}[2]{
	ntextbox base,
	colback=#2!5,
	colframe=#2,
	title={Box~\thetcbcounter:\;#1},
	title after break={Box~\thetcbcounter:\; continued.},
	borderline={0pt}{0pt}{#2},
	segmentation style={solid, #2},
}
\newcommand{\ntextbox}[3]{\begin{ntextboxenv}{#1}{#3}#2\end{ntextboxenv}}

% Produce a answer box with white background and black frame.
% First (optional) argument is the height of the box.
\newcommand{\answerbox}[1][4cm]{
\begin{tcolorbox}[
    width=\linewidth,
    height=#1,
    colback=white,
    colframe=black,
    boxrule=0.5pt
]
\vspace*{\fill}
\end{tcolorbox}
}

% produce an answerbox inline for a small field.  First (optional) argument is the width of the box.
\newcommand{\numberbox}[1][2cm]{%
  \tcbox[
    on line,
    nobeforeafter,
    colback=white,
    colframe=black,
    boxrule=0.5pt,
    boxsep=0pt
  ]{\makebox[#1]{\rule{0pt}{2.5ex}}}%
}

